# Copy to .env and fill in. The app reads these at startup.

# Required: your Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model (defaults to claude-opus-4-8)
JOBAPPLY_MODEL=claude-opus-4-8

# Optional: SQLite database location
JOBAPPLY_DATABASE_URL=sqlite:///./job_apply.db
